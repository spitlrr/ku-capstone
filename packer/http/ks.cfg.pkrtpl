# Kickstart file for Rocky Linux 9 minimal installation
# network installation
url --url=http://dl.rockylinux.org/vault/rocky/9.6/BaseOS/x86_64/os/
repo --name="AppStream" --baseurl=http://dl.rockylinux.org/vault/rocky/9.6/AppStream/x86_64/os/

# use text mode install
text
# keyboard and language
keyboard us
lang en_US.UTF-8

# network information
network --bootproto=dhcp --device=link --onboot=true --activate --hostname=rocky-base

# disable root account for security
rootpw --lock

# add user and groups
user --name=vagrant  --plaintext --groups=wheel
user --name=capstone --plaintext --groups=wheel


# system services
selinux --enforcing
firewall --enabled --service=ssh
services --enabled="NetworkManager,sshd"

# timezone
timezone America/Chicago --utc

# bootloader and partitioning
bootloader --location=mbr --boot-drive=sda
ignoredisk --only-use=sda
zerombr
clearpart --all --initlabel --disklabel=msdos
part swap --size=1024
part /boot --fstype="xfs" --size=512
part pv.01 --grow --size=1
volgroup vg_root pv.01
logvol / --fstype="xfs" --name=lv_root --vgname=vg_root --size=1 --grow

# packages
%packages --ignoremissing
@^minimal-environment
-iwl*firmware
openssh-server
openssh-clients
NetworkManager
xfsprogs
openscap-scanner
scap-security-guide
python3
rsync
%end

reboot

%post --log=/root/ks-post.log
# enable necessary services
systemctl enable NetworkManager
systemctl enable sshd

# create .ssh directory
mkdir -p /home/capstone/.ssh
chmod 700 /home/capstone/.ssh

# inject dynamic key fromp packer
cat > /home/capstone/.ssh/authorized_keys <<'EOF'
${ssh_public_key}
EOF

# set permissions for the authorized_keys file
mkdir -p /home/vagrant/.ssh

chmod 700 /home/vagrant/.ssh


cat > /home/vagrant/.ssh/authorized_keys <<'EOF'
ssh-rsa  vagrant insecure public key
EOF

chown -R capstone:capstone /home/capstone/.ssh
chown -R vagrant:vagrant /home/vagrant/.ssh
chmod 600 /home/capstone/.ssh/authorized_keys
chmod 600 /home/vagrant/.ssh/authorized_keys

# enable password authentication for Packer to connect-disabled later in cleanup script
sed -ri 's/^\s*#?\s*PasswordAuthentication\s+.*/PasswordAuthentication no/' /etc/ssh/sshd_config
sed -ri 's/^\s*#?\s*PubkeyAuthentication\s+.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config

# allow passwordless sudo for user
echo "vagrant ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/vagrant
echo "capstone ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/capstone
chmod 0440 /etc/sudoers.d/vagrant /etc/sudoers.d/capstone

restorecon -Rv /home/capstone/.ssh || true
restorecon -Rv /home/vagrant/.ssh || true
systemctl restart sshd

%end